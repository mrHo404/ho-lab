---
# Copy to group_vars/homelab/vault.yml and encrypt with ansible-vault encrypt
# ansible-vault create group_vars/homelab/vault.yml

# Pi-hole
vault_pihole_password: "CHANGE_ME"

# Immich
vault_immich_db_password: "CHANGE_ME"

# qBittorrent
vault_qbittorrent_webui_password: "CHANGE_ME"

# Gluetun — choose ONE provider block

# ProtonVPN (WireGuard — recommended for port forwarding)
vault_protonvpn_wireguard_private_key: ""
vault_protonvpn_wireguard_addresses: "10.2.0.2/32"

# NordVPN (OpenVPN)
vault_nordvpn_openvpn_user: ""
vault_nordvpn_openvpn_password: ""

# Grafana
vault_grafana_admin_password: "CHANGE_ME"

# Uptime Kuma (set on first login — placeholder for future API key)
vault_uptime_kuma_api_key: ""
