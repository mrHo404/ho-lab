services:
  uptime-kuma:
    image: {{ images.uptime_kuma }}
    container_name: uptime-kuma
    restart: unless-stopped
    ports:
      - "{{ monitoring.uptime_kuma_port }}:3001"
    volumes:
      - {{ ho_lab_root }}/uptime-kuma:/app/data
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001"]
      interval: 30s
      timeout: 10s
      retries: 3

  prometheus:
    image: {{ images.prometheus }}
    container_name: prometheus
    restart: unless-stopped
    ports:
      - "{{ monitoring.prometheus_port }}:9090"
    volumes:
      - {{ ho_lab_root }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ ho_lab_root }}/prometheus/data:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ monitoring.retention }}"
    extra_hosts:
      - "host.docker.internal:host-gateway"

  grafana:
    image: {{ images.grafana }}
    container_name: grafana
    restart: unless-stopped
    ports:
      - "{{ monitoring.grafana_port }}:3000"
    env_file:
      - .env
    environment:
      - GF_SECURITY_ADMIN_USER=admin
    volumes:
      - {{ ho_lab_root }}/grafana:/var/lib/grafana
    depends_on:
      - prometheus

  node-exporter:
    image: {{ images.node_exporter }}
    container_name: node-exporter
    restart: unless-stopped
    pid: host
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - "--path.procfs=/host/proc"
      - "--path.sysfs=/host/sys"
      - "--path.rootfs=/rootfs"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"

  cadvisor:
    image: {{ images.cadvisor }}
    container_name: cadvisor
    restart: unless-stopped
    ports:
      - "{{ monitoring.cadvisor_port }}:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro

networks:
  default:
    name: monitoring-net
