services:
  immich-server:
    image: {{ images.immich_server }}
    container_name: immich_server
    restart: unless-stopped
    ports:
      - "{{ immich.port }}:2283"
    volumes:
      - {{ immich.library_path }}:/usr/src/app/upload
      - /etc/localtime:/etc/localtime:ro
    env_file:
      - .env
    depends_on:
      redis:
        condition: service_started
      database:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:2283/api/server/ping"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s

  immich-machine-learning:
    image: {{ images.immich_ml }}
    container_name: immich_machine_learning
    restart: unless-stopped
    volumes:
      - model-cache:/cache
    env_file:
      - .env

  redis:
    image: {{ images.redis }}
    container_name: immich_redis
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3

  database:
    image: {{ images.postgres }}
    container_name: immich_postgres
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - {{ ho_lab_root }}/immich/db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U immich -d immich"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

volumes:
  model-cache:
