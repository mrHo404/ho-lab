{# Rendered per-server; mc variable holds server dict #}
services:
  minecraft:
    image: {{ images.minecraft }}
    container_name: mc-{{ mc.name }}
    restart: unless-stopped
    ports:
      - "{{ mc.bind_address | default(ansible_host) }}:{{ mc.port }}:25565"
{% if mc.enable_rcon | default(false) %}
      - "{{ mc.rcon_port | default(25575) }}:25575"
{% endif %}
    environment:
      EULA: "TRUE"
{% if mc.curseforge_modpack is defined and mc.curseforge_modpack | length > 0 %}
      TYPE: "AUTO_CURSEFORGE"
      CF_API_KEY: "{{ vault_curseforge_api_key }}"
      CF_SLUG: "{{ mc.curseforge_modpack }}"
{% else %}
      TYPE: "{{ mc.type | upper }}"
{% endif %}
      VERSION: "{{ mc.version | default('LATEST') }}"
      MEMORY: "{{ mc.memory | default('4G') }}"
      TZ: {{ ho_lab_timezone }}
      USE_AIKAR_FLAGS: "{{ mc.use_aikar_flags | default(true) | string | lower }}"
      DIFFICULTY: "{{ mc.difficulty | default('normal') }}"
      MODE: "{{ mc.gamemode | default('survival') }}"
      MAX_PLAYERS: "{{ mc.max_players | default(10) }}"
      MOTD: "{{ mc.motd | default('ho-lab ' ~ mc.name) }}"
      VIEW_DISTANCE: "{{ mc.view_distance | default(10) }}"
      SIMULATION_DISTANCE: "{{ mc.simulation_distance | default(8) }}"
      MAX_TICK_TIME: "{{ mc.max_tick_time | default(-1) }}"
      ONLINE_MODE: "{{ mc.online_mode | default(true) | string | lower }}"
      ENABLE_WHITELIST: "{{ mc.enforce_whitelist | default(false) | string | lower }}"
      REMOVE_OLD_MODS: "{{ mc.remove_old_mods | default(true) | string | lower }}"
{% if mc.whitelist is defined and mc.whitelist | length > 0 %}
      WHITELIST: "{{ mc.whitelist }}"
{% endif %}
{% if mc.ops is defined and mc.ops | length > 0 %}
      OPS: "{{ mc.ops }}"
{% endif %}
{% if mc.enable_rcon | default(false) %}
      ENABLE_RCON: "true"
      RCON_PASSWORD: "{{ vault_minecraft_rcon_password }}"
      RCON_PORT: "25575"
{% endif %}
{% if mc.modrinth_projects is defined and mc.modrinth_projects | length > 0 %}
      MODRINTH_PROJECTS: |
{% for project in mc.modrinth_projects %}
        {{ project }}
{% endfor %}
{% endif %}
{% if mc.version_from_modrinth | default(false) %}
      VERSION_FROM_MODRINTH_PROJECTS: "true"
{% endif %}
{% if mc.modpack is defined %}
      MODPACK_PLATFORM: "{{ mc.modpack.platform }}"
      MODPACK: "{{ mc.modpack.id }}"
{% endif %}
{% if mc.extra_env is defined %}
{% for key, value in mc.extra_env.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
    volumes:
      - {{ minecraft.base_path }}/{{ mc.name }}:/data
    deploy:
      resources:
        limits:
          memory: {{ mc.memory_limit | default(mc.memory | default('4G')) }}
    healthcheck:
      test: ["CMD", "mc-health"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 300s
